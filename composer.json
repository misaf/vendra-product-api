{
    "name": "misaf/vendra-product-api",
    "description": "API services for the vendra-product module",
    "keywords": [
        "laravel",
        "filamentphp",
        "misaf",
        "vendra",
        "product-api"
    ],
    "homepage": "https://github.com/misaf/vendra-product-api",
    "license": "MIT",
    "authors": [
        {
            "name": "Ehsan Mahmoodi",
            "email": "misaf.1990@gmail.com",
            "role": "Developer"
        }
    ],
    "type": "vendra-module",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "misaf/vendra-api": "^0.0.1",
        "misaf/vendra-multimedia-api": "^0.0.1",
        "misaf/vendra-product": "^0.0.1",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.10.0",
        "laravel-json-api/testing": "^3.1",
        "laravel/boost": "^2.4.8",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7.2",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-profanity": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "staudenmeir/belongs-to-through": "^2.18"
    },
    "autoload": {
        "psr-4": {
            "Misaf\\VendraProductApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Misaf\\VendraProductApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Misaf\\VendraProductApi\\Providers\\ProductApiServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-master": "13.x-dev"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "support": {
        "issues": "https://github.com/misaf/vendra-product-api/issues",
        "source": "https://github.com/misaf/vendra-product-api"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "$schema": "https://getcomposer.org/schema.json"
}
